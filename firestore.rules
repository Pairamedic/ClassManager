rules_version = '2';

// CM Simulator — Firestore security rules
//
// Model: every saved scenario / session is owned by the authenticated user
// that created it (`uid` field). Owners — and only owners — may read, update,
// or delete their own documents. There is no public/global read: a clone that
// lifts the Firebase config still cannot reach any user's data, and App Check
// (configured separately) blocks calls that don't originate from the real app.
service cloud.firestore {
  match /databases/{database}/documents {

    // True when the request is authenticated and the document being written
    // is stamped with the caller's own uid.
    function isOwnerOnCreate() {
      return request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // True when the request is authenticated and already owns the stored doc.
    function ownsExisting() {
      return request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /acls_scenarios/{docId} {
      allow create: if isOwnerOnCreate();
      allow read, update, delete: if ownsExisting();
    }

    match /acls_sessions/{docId} {
      allow create: if isOwnerOnCreate();
      allow read, update, delete: if ownsExisting();
    }

    // Shared, read-only content catalog. Any signed-in user may read it;
    // clients may never write. It is populated out-of-band by the seed script
    // (scripts/seed-content.mjs) using Admin credentials, which bypass rules.
    match /acls_content/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
