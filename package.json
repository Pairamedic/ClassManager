{
  "name": "cm-simulator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:offline": "vite --mode offline",
    "build:offline": "vite build --mode offline",
    "preview:offline": "vite preview --mode offline",
    "desktop": "npm run build:offline && electron .",
    "dist:win": "npm run build:offline && electron-builder --win",
    "dist:mac": "npm run build:offline && electron-builder --mac",
    "dist:linux": "npm run build:offline && electron-builder --linux"
  },
  "dependencies": {
    "firebase": "^10.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5"
  },
  "build": {
    "appId": "com.cmsimulator.app",
    "productName": "CM Simulator",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/pwa-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CM Simulator"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/pwa-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/pwa-512.png"
    }
  }
}
