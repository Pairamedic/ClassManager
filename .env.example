# Firebase Configuration
# Copy this file to .env and fill in your project values.
# Firebase Console → Project Settings → Your apps → SDK setup & config

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App Check (reCAPTCHA v3) — optional but recommended.
# Firebase Console → App Check → register the app with reCAPTCHA v3, then paste
# the reCAPTCHA v3 *site key* here. When set, only the real app can reach the
# backend; a clone that copies this public config is rejected.
VITE_FIREBASE_APPCHECK_KEY=
